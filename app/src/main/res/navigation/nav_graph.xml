<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/introFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.auth.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_myShopListFragment"
            app:destination="@id/myShopListFragment" />
    </fragment>

    <action
        android:id="@+id/action_global_profileFragment"
        app:destination="@id/profileFragment" />
    <action
        android:id="@+id/action_global_homeFragment"
        app:destination="@id/homeFragment" />
    <action
        android:id="@+id/action_global_shopListFragment"
        app:destination="@id/myShopListFragment" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="prm392.orderfood.androidapp.ui.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_shopDetailFragment"
            app:destination="@id/shopDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/profileFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.customer.ProfileFragment"
        android:label="fragment_profile_menu"
        tools:layout="@layout/fragment_profile_menu" >
        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_profileFragment_to_phoneInputFragment"
            app:destination="@id/phoneInputFragment" />
        <action
            android:id="@+id/action_profileFragment_to_pendingOrdersFragment"
            app:destination="@id/pendingOrdersFragment" />
    </fragment>
    <fragment
        android:id="@+id/introFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.intro.IntroFragment"
        android:label="fragment_intro"
        tools:layout="@layout/fragment_intro" >
        <action
            android:id="@+id/action_introFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_introFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.auth.RegisterFragment"
        android:label="RegisterFragment" >
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/otpFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.auth.OtpFragment"
        android:label="OtpFragment" />
    <fragment
        android:id="@+id/phoneInputFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.auth.PhoneInputFragment"
        android:label="PhoneInputFragment" >
        <action
            android:id="@+id/action_phoneInputFragment_to_otpFragment"
            app:destination="@id/otpFragment" />
    </fragment>
    <fragment
        android:id="@+id/myShopListFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.shopOwner.MyShopListFragment"
        android:label="MyShopListFragment" >
        <action
            android:id="@+id/action_myShopListFragment_to_shopFormFragment"
            app:destination="@id/shopFormFragment" />
        <action
            android:id="@+id/action_myShopListFragment_to_shopDetailFragment"
            app:destination="@id/shopDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/shopFormFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.shopOwner.ShopFormFragment"
        android:label="ShopFormFragment" />
    <fragment
        android:id="@+id/shopDetailFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.shopOwner.ShopDetailFragment"
        android:label="fragment_detail_shop"
        tools:layout="@layout/fragment_detail_shop" >
        <action
            android:id="@+id/action_shopDetailFragment_to_addProductFragment"
            app:destination="@id/addProductFragment" />
        <action
            android:id="@+id/action_shopDetailFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
        <action
            android:id="@+id/action_shopDetailFragment_to_orderListFragment"
            app:destination="@id/orderListFragment" />
    </fragment>
    <fragment
        android:id="@+id/addProductFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.shopOwner.AddProductFragment"
        android:label="fragment_add_product"
        tools:layout="@layout/fragment_add_product" />
    <fragment
        android:id="@+id/cartFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.customer.CartFragment"
        android:label="fragment_food_order"
        tools:layout="@layout/fragment_food_order" >
        <action
            android:id="@+id/action_cartFragment_to_paymentFragment"
            app:destination="@id/paymentFragment" />
    </fragment>
    <fragment
        android:id="@+id/orderListFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.shopOwner.OrderListFragment"
        android:label="OrderListFragment" />
    <fragment
        android:id="@+id/paymentFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.customer.PaymentFragment"
        android:label="PaymentFragment" />
    <fragment
        android:id="@+id/walletFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.customer.WalletFragment"
        android:label="WalletFragment"
        tools:layout="@layout/fragment_wallet" />
    <fragment
        android:id="@+id/pendingOrdersFragment"
        android:name="prm392.orderfood.androidapp.ui.fragment.customer.PendingOrdersFragment"
        android:label="fragment_pending_orders"
        tools:layout="@layout/fragment_pending_orders" />
</navigation>