<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="shapeAppearance">@style/AppButtonShape</item>
        <item name="backgroundTint">@color/primary_color</item>
        <item name="rippleColor">@color/orange_primary</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@anim/button_state_animator</item>
    </style>
</resources>