<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cardview_light_background"
    tools:context=".ui.fragment.customer.CartFragment">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_edittext"
        android:elevation="6dp"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Restaurant name with icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_store"
                android:layout_marginEnd="12dp"
                app:tint="@color/primary_color" />

            <TextView
                android:id="@+id/tvShopName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Restaurant Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

        <!-- Address with icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                android:layout_marginEnd="12dp"
                app:tint="@color/red"  />

            <TextView
                android:id="@+id/tvShopAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="123 Main Street, District 1, HCMC"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

        <!-- Opening hours with icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_clock"
                android:layout_marginEnd="12dp"
                app:tint="@color/green_500" />

            <TextView
                android:id="@+id/tvShopEndTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open ⋅ Closes at 10:00 PM"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"/>
        </LinearLayout>
    </LinearLayout>


    <!-- Food items list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/foodItemsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="72dp"
        tools:listitem="@layout/item_food"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/cartSummaryLayout"/>

    <!-- Cart summary sticky footer -->
    <LinearLayout
        android:id="@+id/cartSummaryLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Cart row -->
        <LinearLayout
            android:id="@+id/cartRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_shopping_cart"
                app:tint="@color/primary_color" />

            <TextView
                android:id="@+id/tvTotalItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 items"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/totalPriceTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24.500 VND"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Payment method selection -->

        <!-- Checkout button -->
        <RadioGroup
            android:id="@+id/paymentMethodGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- COD Payment with icon -->
            <RadioButton
                android:id="@+id/radioCod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="COD"
                android:drawableStart="@drawable/ic_delivery_truck"
                android:drawableTint="@color/green_500"
                android:drawablePadding="8dp"
                android:paddingVertical="8dp"
                android:paddingEnd="16dp"/>

            <!-- Bank Transfer with icon -->
            <RadioButton
                android:id="@+id/radioBank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Bank Transfer"
                android:drawableTint="@color/primary_color"
                android:drawableStart="@drawable/ic_bank"
            android:drawablePadding="8dp"
            android:paddingVertical="8dp"/>
        </RadioGroup>

        <Button
            android:id="@+id/checkoutButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Order Now"
            android:textColor="@color/white"
            android:textAllCaps="false"/>
    </LinearLayout>

    <TextView
        android:id="@+id/emptyCartTextView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Empty Cart"
        android:gravity="center"
        android:textSize="16sp"/>


</androidx.constraintlayout.widget.ConstraintLayout>