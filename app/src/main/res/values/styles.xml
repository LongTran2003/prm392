<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Button Style -->
    <style name="AppButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="shapeAppearance">@style/AppButtonShape</item>
        <item name="backgroundTint">@color/primary_color</item>
        <item name="rippleColor">@color/orange_primary</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@anim/button_state_animator</item>
    </style>

    <!-- Button Shape -->
    <style name="AppButtonShape" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
        <item name="android:fontFamily">@font/abeezee</item>
    </style>
</resources>